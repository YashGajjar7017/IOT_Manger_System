{
  "name": "iot-monitor-system",
  "version": "2.0.0",
  "description": "IoT Monitor Gateway MERN Desktop Dashboard",
  "main": "main.js",
  "scripts": {
    "build": "vite build",
    "electron-start": "electron .",
    "electron-build": "npm run build && electron-builder",
    "electron-dev": "concurrently \"npm start\" \"wait-on http://localhost:4000 && electron .\""
  },
  "keywords": [
    "IoT",
    "Electron",
    "React",
    "MERN",
    "Express",
    "MongoDB"
  ],
  "author": "Antigravity",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^8.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^28.2.0",
    "vite": "^5.0.10",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.iot_PubSub.app",
    "productName": "IOT Monitor System",
    "icon": "icon/logo.png",
    "files": [
      "frontend-build/**/*",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "directories": {
      "buildResources": "public",
      "output": "installer-release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}